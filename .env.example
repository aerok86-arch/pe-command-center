# Anthropic API Key
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Notion Integration Token
# https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# Notion DB IDs
NOTION_IDEA_BANK_DB=f10b49af-653e-42a6-85a4-a1702d7f6100
NOTION_DEAL_SHEET_DB=2da09bfe-5079-8087-83ff-c3c00d5f34a3

# NextAuth
# 랜덤 문자열 생성: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# 로컬 개발 시: http://localhost:3000 / 배포 시: https://pe-command-center.vercel.app
NEXTAUTH_URL=https://pe-command-center.vercel.app

# Google OAuth
# https://console.cloud.google.com/ → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# 허용할 Google 계정 이메일 (콤마 구분, 미입력 시 전체 허용)
ALLOWED_EMAILS=you@gmail.com,colleague@gmail.com
